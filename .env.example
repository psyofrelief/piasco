# Your database connection string for Prisma
DATABASE_URL="postgresql://username:password@localhost:5432/your_database_name"

# Generate a random secret using: openssl rand -base64 32
AUTH_SECRET="your_random_auth_secret"

# Google OAuth Credentials
AUTH_GOOGLE_ID="your_google_client_id"
AUTH_GOOGLE_SECRET="your_google_client_secret"

# Your public application URL (e.g., http://localhost:3000 for development)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Token for mail service client-side access
NEXT_PUBLIC_MAIL_ACCESS_TOKEN="your_mail_access_token"

# API key for Resend email service
RESEND_API_KEY="re_your_resend_api_key"
